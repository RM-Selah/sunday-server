# Required — Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the default model (claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — server port (default 3456)
# PORT=3456

# Optional — Twilio WhatsApp (all three required to enable WhatsApp features)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional — Supabase (set in app Settings instead if you prefer)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=eyJ...
